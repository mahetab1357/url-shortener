# Copy to .env for local (non-Docker) development.
DATABASE_URL=postgresql+psycopg://shortener:shortener@localhost:5433/shortener
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
BASE_HOST=http://localhost:8000
SHORT_CODE_LENGTH=7
SHORT_CODE_MAX_ATTEMPTS=5
ANALYTICS_SERVICE_URL=http://localhost:8081
ANALYTICS_REQUEST_TIMEOUT_SECONDS=2.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
